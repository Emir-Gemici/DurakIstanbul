<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="com.example.emirgemici">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.AppCompat.NoActionBar"
        tools:targetApi="31">

        <!-- 🚀 ANA GİRİŞ EKRANI -->
        <activity
            android:name=".ModeSelectionActivity"
            android:exported="true"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 🚀 DİĞER PENCERELER (AKTİVİTELER) -->
        <!-- Her birinin burada kayıtlı olması, Intent ile açılabilmeleri için şarttır -->

        <activity
            android:name=".DistrictActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".GameActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".CertificatesActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".LeaderboardActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

    </application>

</manifest>